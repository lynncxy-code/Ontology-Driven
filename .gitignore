# Python
__pycache__/
*.pyc
*.pyo
.env
venv/

# Node
node_modules/

# Docker
.docker/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.suo
*.user

# UE5 (only source code is tracked)
*.uproject
Binaries/
Intermediate/
Saved/
DerivedDataCache/

# ue_project 整体忽略，仅追踪 Plugins 下的插件源码
# （Binaries/Intermediate 已被上方通用规则覆盖）
ue_project/*
!ue_project/Plugins/

# 大型二进制资产（模型、贴图、训练数据）— 不再提交，避免仓库膨胀
*.dxf
*.fbx
*.glb
*.gltf
assets/usd_cache/
exports/*_trajectory.json
exports/*.usda
exports/*.usd

# Claude Code 本地状态
.claude/settings.local.json
.claude/worktrees/

# SQLite 数据库（运行时生成）
backend/lite/db/*.db
